{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/app.py"
        }
    ],
    "env": {
        "FLASK_ENV": "production",
        "REDIS_HOST": "your-redis-host.com",
        "REDIS_PORT": "6379",
        "REDIS_PASSWORD": "your-redis-password"
    }
}